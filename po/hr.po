#. Translators: These are search terms to find this application. Do NOT translate or localize the semicolons. The list MUST also end with a semicolon.
#: data/io.github.josephmawa.SpellingBee.desktop.in:9
msgid "Learn;English;Word:Vocabulary;Spelling;Spell;Game;Puzzle;Bee;"
msgstr "Uči;english;engleski;riječ;rječnik;pravopis;igra;zagonetka;Bee;"

#: data/io.github.josephmawa.SpellingBee.metainfo.xml.in:8
msgid "Learn new English words"
msgstr "Uči nove engleske riječi"

#: data/io.github.josephmawa.SpellingBee.metainfo.xml.in:10
msgid "Use Spelling Bee to enhance your English vocabulary while having fun."
msgstr ""
"Koristi Spelling Bee i obogati svoj engleski vokabular dok se zabavljaš."

#: data/io.github.josephmawa.SpellingBee.metainfo.xml.in:11
msgid "Below are the main features:"
msgstr "Glavne značajke su:"

#: data/io.github.josephmawa.SpellingBee.metainfo.xml.in:13
msgid "Provides thousands of words"
msgstr "Pruža tisuće riječi"

#: data/io.github.josephmawa.SpellingBee.metainfo.xml.in:14
msgid "You can play it offline"
msgstr "Može se igrati offline"

#: data/io.github.josephmawa.SpellingBee.metainfo.xml.in:15
msgid "It provides links to the meaning of words"
msgstr "Pruža poveznice na značenje riječi"

#: data/io.github.josephmawa.SpellingBee.metainfo.xml.in:16
msgid "You can view puzzle history"
msgstr "Prikaz povijest zagonetki"

#: data/io.github.josephmawa.SpellingBee.metainfo.xml.in:17
msgid "You can view your score"
msgstr "Prikaz rezultata"

#: data/io.github.josephmawa.SpellingBee.metainfo.xml.in:18
msgid "Switch to dark, light, or system mode"
msgstr "Mijenjanje moduse na tamni, svijetli ili sustavski"

#: data/io.github.josephmawa.SpellingBee.metainfo.xml.in:23
msgid "Joseph Mawa"
msgstr "Joseph Mawa"

